# MindIQ — Environment Configuration
# Copy to .env and fill in your values

# Database (SQLite by default, no config needed)
DATABASE_URL=sqlite:///./mindiq.db

# Payment mode: "mock" (simulates payment) or "stripe" (real Stripe checkout)
PAYMENT_MODE=mock

# Stripe (only needed if PAYMENT_MODE=stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (for AI-generated reports; fallback template used if empty)
OPENAI_API_KEY=sk-...

# Frontend URL (for CORS and payment redirects)
FRONTEND_URL=http://localhost:3000

# Pricing
REPORT_PRICE_CENTS=399
REPORT_CURRENCY=usd
