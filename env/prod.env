# MindIQ — Production Environment
APP_ENV=prod

# Database
DATABASE_URL=sqlite:///./mindiq_prod.db

# Payment (real Stripe keys)
PAYMENT_MODE=stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI
OPENAI_API_KEY=sk-...

# Frontend (change to your production domain)
FRONTEND_URL=https://your-domain.com

# Pricing
REPORT_PRICE_CENTS=399
REPORT_CURRENCY=usd

# OAuth / Social login
SOCIAL_MODE=oauth
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://your-domain.com/auth/twitter/callback
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
OAUTH_STATE_SECRET=change_me_prod_state_secret

# Dev test account (MUST stay false in prod)
DEV_ACCOUNT_ENABLED=false
DEV_ACCOUNT_EMAIL=dev@dev
DEV_ACCOUNT_PASSWORD=dev@dev

# JWT
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# WhatsApp (Meta) OAuth
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://your-domain.com/auth/whatsapp/callback

# --- Frontend env ---
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_DEV_MODE=false
