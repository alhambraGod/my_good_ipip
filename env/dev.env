# MindIQ — Development Environment
APP_ENV=dev

# Database
DATABASE_URL=sqlite:///./mindiq_dev.db

# Payment (mock in dev)
PAYMENT_MODE=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI (optional in dev, fallback template used if empty)
OPENAI_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000

# Pricing
REPORT_PRICE_CENTS=399
REPORT_CURRENCY=usd

# OAuth / Social login
SOCIAL_MODE=oauth
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:3000/auth/twitter/callback
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
OAUTH_STATE_SECRET=change_me_dev_state_secret

# Dev test account
DEV_ACCOUNT_ENABLED=true
DEV_ACCOUNT_EMAIL=dev@dev
DEV_ACCOUNT_PASSWORD=dev@dev

# JWT
JWT_SECRET=dev_jwt_secret_change_me

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# WhatsApp (Meta) OAuth
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/auth/whatsapp/callback

# --- Frontend env ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_DEV_MODE=true
